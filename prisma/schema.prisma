generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model clusterdata {
  cluster_id        Int    @id @default(autoincrement()) @map("cluster_id")
  cluster_name  String  @db.VarChar(255) @map("cluster_name")
  status String @db.VarChar(255) @map("status")
  ins_date_time    DateTime @default(now()) @map("ins_date_time") // Insert date and time
  verify_date_time    DateTime @default(now()) @map("verify_date_time") // Insert date and time

  @@map("tbl_cluster") 
}

